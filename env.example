# ── Database ──────────────────────────────────────
# Render PostgreSQL connection string (auto-set by Render)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── JWT ───────────────────────────────────────────
SECRET_KEY=replace-with-a-long-random-string-at-least-32-chars
TOKEN_EXPIRE_HOURS=12

# ── Default admin (first boot seed) ──────────────
DEFAULT_ADMIN_ID=admin
DEFAULT_ADMIN_PW=admin1234

# ── CORS (comma-separated origins) ───────────────
# Example: https://yourname.github.io,http://localhost:3000
ALLOWED_ORIGINS=*

# ── Cloudinary（写真ストレージ）─────────────────────
# https://console.cloudinary.com → Dashboard で確認
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Auto cleanup ──────────────────────────────────
# 0 = disabled, 30 = delete USED items older than 30 days (runs daily at 02:00 UTC)
AUTO_CLEANUP_DAYS=0
